{
  "manifest_version": 3,
  "name": "Classroom Speaker - TOEIC Trainer",
  "version": "2.0",
  "description": "大学の中教室スピーカーのようなこもり音響効果をかけます",
  "permissions": ["tabCapture", "offscreen", "tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Classroom Speaker"
  },
  "background": {
    "service_worker": "background.js"
  }
}
